{
  "name": "ai-hubs-desktop",
  "version": "3.0.0",
  "description": "AI Hubs 桌面客户端 — 新一代智能 Agent 平台",
  "main": "electron/main.js",
  "scripts": {
    "electron:dev": "electron .",
    "electron:build": "electron-builder",
    "frontend:build": "cd frontend && npm run build"
  },
  "build": {
    "appId": "com.aihubs.desktop",
    "productName": "AI Hubs",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "frontend/dist/**/*",
      "main.py",
      "src/**/*",
      "config.yaml",
      "requirements.txt"
    ],
    "win": {
      "target": "nsis",
      "icon": "electron/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "electron/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "electron/icon.png"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0"
  }
}
